		(uuid "a4108d97-6f96-4dd0-ae4a-b5238fed27f9")
	)
	(text "Double up mosfets to battery connector. \nThe ones we chose here are rated to 40A \ncontinnous, but we are close to being \nlimited by copper trace width."
		(exclude_from_sim no)
		(at 510.032 184.912 0)
		(effects
			(font
				(size 0.8 0.8)
			)
			(justify left)
		)
		(uuid "bbc2d9ca-dd9c-42ad-87ae-ebcab53cf171")
	)
